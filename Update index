<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HarvestFlow — Funnel Specialist & AI UGC Video Producer</title>
<meta name="description" content="AI-generated UGC video ads + the funnels they convert on, built for DTC pet and wellness brands.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    --black: #050608;
    --black-2: #0C0E12;
    --panel: #15171C;
    --bone: #F5F3EF;
    --bone-dim: rgba(245,243,239,0.7);
    --accent: #C9A24B;       /* warm cinematic gold, restrained */
    --accent-dim: #9C7C34;
    --line: rgba(245,243,239,0.10);
    --muted: #8A8D93;

    --display: 'Inter Tight', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --body: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--body);
    color: var(--bone);
    background: var(--black);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img { display: block; max-width: 100%; }
  a { color: inherit; }

  .container { max-width: 1280px; margin: 0 auto; padding: 0 32px; }

  h1, h2, h3 {
    font-family: var(--display);
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -0.02em;
  }

  :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  @media (prefers-reduced-motion: reduce) { * { animation: none !important; transition: none !important; } }

  /* ================= SCROLL REVEAL ================= */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  .reveal.in-view { opacity: 1; transform: translateY(0); }
  .reveal-stagger.in-view .stagger-item {
    opacity: 1;
    transform: translateY(0);
  }
  .stagger-item {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .stagger-item:nth-child(1) { transition-delay: 0.05s; }
  .stagger-item:nth-child(2) { transition-delay: 0.12s; }
  .stagger-item:nth-child(3) { transition-delay: 0.19s; }
  .stagger-item:nth-child(4) { transition-delay: 0.26s; }
  .stagger-item:nth-child(5) { transition-delay: 0.33s; }
  .stagger-item:nth-child(6) { transition-delay: 0.40s; }

  @media (prefers-reduced-motion: reduce) {
    .reveal, .stagger-item { opacity: 1; transform: none; transition: none; }
  }

  /* ================= COUNTDOWN BAR ================= */
  .announce {
    background: linear-gradient(90deg, #0A0B0D 0%, #161310 50%, #0A0B0D 100%);
    border-bottom: 1px solid rgba(201,162,75,0.25);
    color: var(--bone);
    text-align: center;
    font-size: 0.82rem;
    padding: 11px 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .announce strong { color: var(--accent); font-weight: 700; }
  .announce .pill {
    border: 1px solid rgba(201,162,75,0.4);
    border-radius: 100px;
    padding: 3px 12px;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    font-size: 0.78rem;
    color: var(--accent);
  }

  /* ================= FLOATING PILL NAV ================= */
  .nav-wrap { padding: 22px 24px 0; }
  nav {
    max-width: 1280px;
    margin: 0 auto;
    background: rgba(21,23,28,0.7);
    backdrop-filter: blur(14px);
    border: 1px solid var(--line);
    border-radius: 100px;
    padding: 14px 28px;
  }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; }
  .logo {
    font-family: var(--display);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--bone);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo .mark {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--black);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.78rem;
    font-weight: 900;
  }
  .nav-links { display: flex; gap: 34px; list-style: none; }
  .nav-links li { white-space: nowrap; margin-right: 0; }
  .nav-links li:not(:last-child) { margin-right: 34px; }
  .nav-links a {
    text-decoration: none;
    color: var(--bone-dim);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
    transition: color 0.2s ease;
  }
  .nav-links a:hover { color: var(--accent); }
  .nav-cta {
    background: var(--accent);
    color: var(--black) !important;
    padding: 11px 22px;
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 100px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .nav-mobile-hide { display: flex; }

  /* ================= HERO ================= */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 62% 30%;
  }
  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, var(--black) 0%, rgba(5,6,8,0.85) 28%, rgba(5,6,8,0.25) 55%, rgba(5,6,8,0.55) 100%),
      linear-gradient(180deg, rgba(5,6,8,0.2) 0%, transparent 30%, rgba(5,6,8,0.5) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 80px 0 60px;
    width: 100%;
  }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 22px;
  }
  .hero-eyebrow span {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .hero-eyebrow .s1 { color: var(--accent); }
  .hero-eyebrow .s2 { color: var(--bone-dim); }
  .dot { color: var(--muted); }

  .hero h1 {
    font-size: clamp(2.6rem, 6.4vw, 5.2rem);
    color: var(--bone);
    max-width: 760px;
    margin-bottom: 26px;
  }
  .hero h1 .accent { color: var(--accent); }

  .hero-sub {
    font-size: 1.08rem;
    color: var(--bone-dim);
    max-width: 480px;
    margin-bottom: 38px;
    font-weight: 400;
  }
  .hero-sub strong { color: var(--bone); font-weight: 600; }

  .btn-row { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 44px; }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--accent);
    color: var(--black);
    padding: 18px 34px;
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
  }
  .btn-primary:hover { background: #ddb866; transform: translateY(-1px); }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(245,243,239,0.05);
    color: var(--bone);
    padding: 18px 34px;
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    border: 1px solid var(--line);
    border-radius: 100px;
    backdrop-filter: blur(8px);
  }

  .hero-proof {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .avatar-stack { display: flex; }
  .avatar-stack .av {
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 2px solid var(--black);
    margin-left: -10px;
    background: linear-gradient(135deg, #2a2d34, #1a1c20);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--bone-dim);
  }
  .avatar-stack .av:first-child { margin-left: 0; }
  .hero-proof-text { font-size: 0.86rem; color: var(--bone-dim); }
  .hero-proof-text strong { color: var(--accent); }
  .stars { color: var(--accent); letter-spacing: 1px; font-size: 0.85rem; }

  /* ================= PIPELINE ================= */
  .pipeline {
    background: var(--black-2);
    padding: 100px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .section-eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
    margin-bottom: 18px;
    display: block;
  }
  .pipeline-head { max-width: 640px; margin-bottom: 60px; }
  .pipeline-head h2 { font-size: clamp(2rem, 3.8vw, 2.8rem); color: var(--bone); }

  .pipeline-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
  }
  .pipe-step {
    background: var(--black-2);
    padding: 32px 26px;
    transition: background 0.2s ease;
  }
  .pipe-step:hover { background: var(--panel); }
  .pipe-num {
    font-family: var(--display);
    font-size: 0.78rem;
    color: var(--accent);
    font-weight: 800;
    margin-bottom: 18px;
  }
  .pipe-step h3 {
    font-size: 1.02rem;
    color: var(--bone);
    margin-bottom: 10px;
    font-weight: 700;
  }
  .pipe-step p { font-size: 0.85rem; color: var(--muted); }

  /* ================= PORTFOLIO ================= */
  .portfolio { background: var(--black); padding: 100px 0; border-bottom: 1px solid var(--line); }
  .portfolio-head { max-width: 640px; margin-bottom: 56px; }
  .portfolio-head h2 { font-size: clamp(2rem, 3.8vw, 2.8rem); color: var(--bone); }
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .reel-card {
    position: relative;
    aspect-ratio: 9 / 16;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .reel-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .reel-card.empty {
    flex-direction: column;
    gap: 10px;
  }
  .reel-card.empty .plus {
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 1px dashed var(--line);
    color: var(--muted);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
  }
  .reel-card.empty .label {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0 16px;
  }
  .reel-card img, .reel-card video {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .reel-card iframe {
    width: 100%; height: 100%;
    border: none;
    position: absolute;
    inset: 0;
  }
  .reel-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, transparent 50%, rgba(5,6,8,0.8) 100%);
  }
  .reel-play .circle {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: rgba(245,243,239,0.15);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(245,243,239,0.3);
    display: flex; align-items: center; justify-content: center;
    color: var(--bone);
    font-size: 1.1rem;
  }
  .reel-tag {
    position: absolute;
    bottom: 14px;
    left: 14px;
    right: 14px;
    font-size: 0.74rem;
    color: var(--bone);
    font-weight: 600;
  }

  
  .offer { background: var(--black); padding: 110px 0; }
  .offer-head { text-align: center; max-width: 620px; margin: 0 auto 60px; }
  .offer-head .section-eyebrow { display: flex; justify-content: center; }
  .offer-head h2 { font-size: clamp(2.1rem, 4vw, 3rem); color: var(--bone); }

  .offer-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .offer-card {
    background: linear-gradient(160deg, var(--panel) 0%, var(--black-2) 100%);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 36px 32px;
    position: relative;
    overflow: hidden;
  }
  .offer-card::before {
    content: "";
    position: absolute;
    top: -60%; right: -30%;
    width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(201,162,75,0.15) 0%, transparent 70%);
  }
  .offer-card .tag {
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    color: var(--accent);
    font-weight: 700;
    margin-bottom: 18px;
    display: block;
  }
  .offer-card h3 { font-size: 1.5rem; color: var(--bone); margin-bottom: 14px; }
  .offer-card p.desc { color: var(--bone-dim); font-size: 0.95rem; margin-bottom: 22px; }
  .offer-card ul { list-style: none; }
  .offer-card li {
    font-size: 0.9rem;
    color: var(--bone-dim);
    padding: 11px 0;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 10px;
  }
  .offer-card li::before { content: "—"; color: var(--accent); flex-shrink: 0; }

  /* ================= MID-PAGE IMAGE BREAK ================= */
  .image-break {
    background: var(--black);
    padding: 0;
    border-bottom: 1px solid var(--line);
  }
  .image-break-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }
  .image-break-item {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .image-break-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 12%;
    filter: grayscale(35%) contrast(1.1) brightness(0.78);
    transition: transform 0.5s ease, filter 0.5s ease;
  }
  .image-break-item:hover img {
    transform: scale(1.03);
    filter: grayscale(20%) contrast(1.1) brightness(0.85);
  }
  .image-break-item::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5,6,8,0.55) 0%, rgba(5,6,8,0.35) 35%, rgba(5,6,8,0.4) 60%, rgba(5,6,8,0.75) 100%);
    pointer-events: none;
  }
  .image-break-cap {
    position: absolute;
    bottom: 20px;
    left: 20px;
    font-size: 0.78rem;
    color: var(--bone-dim);
    letter-spacing: 0.04em;
    z-index: 1;
  }
  .image-break-quote {
    position: absolute;
    top: 72%;
    left: 24px;
    right: 24px;
    transform: translateY(-50%);
    z-index: 2;
    text-align: center;
  }
  .image-break-quote .mark {
    font-family: var(--display);
    font-size: 2.4rem;
    color: var(--accent);
    line-height: 0.6;
    display: block;
    margin-bottom: 10px;
    opacity: 0.85;
  }
  .image-break-quote p {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(1.15rem, 2.6vw, 1.55rem);
    line-height: 1.25;
    color: var(--bone);
    letter-spacing: -0.01em;
    text-shadow: 0 2px 16px rgba(0,0,0,0.6);
  }

  /* ================= ABOUT ================= */
  .about {
    background: var(--black-2);
    padding: 110px 0;
    border-bottom: 1px solid var(--line);
  }
  .about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 56px;
    align-items: center;
  }
  .about-photo {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }
  .about-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
  }
  .about-copy h2 {
    font-size: clamp(1.9rem, 3.4vw, 2.5rem);
    color: var(--bone);
    margin-bottom: 22px;
  }
  .about-copy h2 .accent { color: var(--accent); }
  .about-copy p {
    color: var(--bone-dim);
    font-size: 1.02rem;
    margin-bottom: 18px;
    max-width: 540px;
  }
  .about-copy p strong { color: var(--bone); font-weight: 700; }
  .about-signoff {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    font-size: 0.86rem;
    color: var(--muted);
  }
  .about-signoff strong { color: var(--accent); }

  /* ================= TOOLSTACK ================= */
  .stack { background: var(--black-2); padding: 70px 0; border-bottom: 1px solid var(--line); }
  .stack-head { margin-bottom: 28px; }
  .stack-head h2 { font-size: 1.4rem; color: var(--bone); }
  .stack-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .stack-pill {
    font-size: 0.82rem;
    background: var(--panel);
    border: 1px solid var(--line);
    color: var(--bone-dim);
    padding: 10px 18px;
    border-radius: 100px;
  }

  /* ================= PROOF ================= */
  .proof { background: var(--black); padding: 110px 0; }
  .proof-head { text-align: center; max-width: 620px; margin: 0 auto 56px; }
  .proof-head .section-eyebrow { display: flex; justify-content: center; }
  .proof-head h2 { font-size: clamp(2rem, 3.8vw, 2.8rem); color: var(--bone); }

  .client-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 60px; }
  .client-tile {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 24px 16px;
    text-align: center;
  }
  .client-tile .niche { font-size: 0.7rem; letter-spacing: 0.06em; color: var(--accent); font-weight: 700; margin-bottom: 6px; }
  .client-tile .desc { font-size: 0.82rem; color: var(--muted); }

  .testimonial-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .testimonial {
    background: var(--panel);
    border-radius: 12px;
    padding: 32px 28px;
    border-left: 2px solid var(--accent);
  }
  .testimonial p.quote { font-size: 0.94rem; color: var(--bone-dim); margin-bottom: 18px; }
  .testimonial .name { font-weight: 700; font-size: 0.88rem; color: var(--bone); }
  .testimonial .role { font-size: 0.78rem; color: var(--muted); }

  /* ================= LEAD FORM ================= */
  .lead-section {
    background: linear-gradient(180deg, var(--black-2) 0%, var(--black) 100%);
    padding: 110px 0;
  }
  .lead-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .lead-copy h2 { font-size: clamp(2.1rem, 4vw, 2.9rem); color: var(--bone); margin-bottom: 20px; }
  .lead-copy h2 .accent { color: var(--accent); }
  .lead-copy p { color: var(--bone-dim); font-size: 1rem; max-width: 440px; }

  .lead-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 44px;
  }
  .lead-card h3 { font-size: 1.15rem; color: var(--bone); margin-bottom: 6px; }
  .lead-card .sub { color: var(--muted); font-size: 0.88rem; margin-bottom: 26px; }

  #lead-form label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--bone-dim);
    font-weight: 600;
    margin-bottom: 7px;
  }
  #lead-form .field { margin-bottom: 18px; }
  #lead-form input {
    width: 100%;
    padding: 13px 16px;
    border: 1px solid var(--line);
    background: rgba(5,6,8,0.5);
    color: var(--bone);
    font-size: 0.95rem;
    font-family: var(--body);
    border-radius: 8px;
  }
  #lead-form input::placeholder { color: var(--muted); }
  #lead-form input:focus { border-color: var(--accent); outline: none; }
  #lead-form button { width: 100%; justify-content: center; margin-top: 4px; }
  #form-status { margin-top: 14px; font-size: 0.84rem; min-height: 20px; }
  #form-status.success { color: #7fd99a; font-weight: 600; }
  #form-status.error { color: #f08a7a; font-weight: 600; }

  /* ================= FAQ ================= */
  .faq { background: var(--black); padding: 110px 0; }
  .faq-grid { display: grid; grid-template-columns: 0.7fr 1.3fr; gap: 60px; }
  .faq-head h2 { font-size: clamp(2rem, 3.4vw, 2.5rem); color: var(--bone); }
  .faq-item { padding: 24px 0; border-bottom: 1px solid var(--line); }
  .faq-item:first-child { padding-top: 0; }
  .faq-item h3 { font-family: var(--body); font-size: 1rem; font-weight: 700; color: var(--bone); margin-bottom: 8px; }
  .faq-item p { color: var(--bone-dim); font-size: 0.92rem; }

  /* ================= FINAL CTA ================= */
  .final-cta {
    background: radial-gradient(ellipse at center, #1a1610 0%, var(--black) 70%);
